{
  "openapi": "3.1.0",
  "info": {
    "title": "Coding Agent Stats",
    "description": "研发中心 Coding Agent 绩效统计平台",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/projects/{project_id}/members": {
      "post": {
        "tags": [
          "projects"
        ],
        "summary": "添加项目成员",
        "description": "向指定项目添加成员。需要管理员权限。",
        "operationId": "add_project_member_api_v1_projects__project_id__members_post",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Project Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProjectMemberCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "成员添加成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectMemberResponse"
                },
                "example": {
                  "id": 3,
                  "project_id": 1,
                  "user_id": 3,
                  "role": "developer",
                  "username": "wangwu",
                  "email": "wangwu@example.com"
                }
              }
            }
          },
          "401": {
            "description": "未授权访问"
          },
          "403": {
            "description": "权限不足（需要管理员权限）"
          },
          "404": {
            "description": "项目或用户不存在"
          },
          "409": {
            "description": "用户已是项目成员"
          },
          "422": {
            "description": "参数验证错误"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ProjectMemberResponse": {
        "properties": {
          "user_id": {
            "type": "integer",
            "title": "User Id",
            "description": "用户ID"
          },
          "role": {
            "type": "string",
            "enum": [
              "owner",
              "maintainer",
              "developer",
              "member"
            ],
            "title": "Role",
            "description": "成员角色",
            "default": "developer"
          },
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "project_id": {
            "type": "integer",
            "title": "Project Id"
          },
          "joined_at": {
            "type": "string",
            "format": "date-time",
            "title": "Joined At"
          },
          "username": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Username"
          },
          "email": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Email"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "id",
          "project_id",
          "joined_at"
        ],
        "title": "ProjectMemberResponse",
        "description": "Schema for project member response with user details."
      },
      "ProjectMemberCreate": {
        "properties": {
          "user_id": {
            "type": "integer",
            "title": "User Id",
            "description": "用户ID"
          },
          "role": {
            "type": "string",
            "enum": [
              "owner",
              "maintainer",
              "developer",
              "member"
            ],
            "title": "Role",
            "description": "成员角色",
            "default": "developer"
          }
        },
        "type": "object",
        "required": [
          "user_id"
        ],
        "title": "ProjectMemberCreate",
        "description": "Schema for adding a member to a project."
      }
    },
    "securitySchemes": {
      "OAuth2PasswordBearer": {
        "type": "oauth2",
        "flows": {
          "password": {
            "scopes": {},
            "tokenUrl": "/api/v1/auth/login"
          }
        }
      },
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}