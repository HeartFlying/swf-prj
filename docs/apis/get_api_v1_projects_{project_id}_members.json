{
  "openapi": "3.1.0",
  "info": {
    "title": "Coding Agent Stats",
    "description": "研发中心 Coding Agent 绩效统计平台",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/projects/{project_id}/members": {
      "get": {
        "tags": [
          "projects"
        ],
        "summary": "获取项目成员列表",
        "description": "获取指定项目的成员列表，包含用户详细信息。设置simple=true返回数组格式。",
        "operationId": "list_project_members_api_v1_projects__project_id__members_get",
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Project Id"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "description": "页码 (从1开始)",
              "examples": [
                1
              ],
              "default": 1,
              "title": "Page"
            },
            "description": "页码 (从1开始)"
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "minimum": 1,
              "description": "每页数量 (1-100)",
              "examples": [
                20
              ],
              "default": 20,
              "title": "Pagesize"
            },
            "description": "每页数量 (1-100)"
          },
          {
            "name": "simple",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "description": "返回简单数组格式而非分页结构",
              "examples": [
                false
              ],
              "default": false,
              "title": "Simple"
            },
            "description": "返回简单数组格式而非分页结构"
          }
        ],
        "responses": {
          "200": {
            "description": "成功获取成员列表",
            "content": {
              "application/json": {
                "schema": {
                  "anyOf": [
                    {
                      "$ref": "#/components/schemas/ProjectMemberListResponse"
                    },
                    {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ProjectMemberResponse"
                      }
                    }
                  ],
                  "title": "Response List Project Members Api V1 Projects  Project Id  Members Get"
                },
                "examples": {
                  "paginated": {
                    "summary": "分页响应 (simple=false)",
                    "value": {
                      "items": [
                        {
                          "id": 1,
                          "project_id": 1,
                          "user_id": 1,
                          "role": "owner",
                          "username": "zhangsan",
                          "email": "zhangsan@example.com"
                        },
                        {
                          "id": 2,
                          "project_id": 1,
                          "user_id": 2,
                          "role": "developer",
                          "username": "lisi",
                          "email": "lisi@example.com"
                        }
                      ],
                      "total": 8,
                      "page": 1,
                      "pageSize": 20
                    }
                  },
                  "simple": {
                    "summary": "数组响应 (simple=true)",
                    "value": [
                      {
                        "id": 1,
                        "project_id": 1,
                        "user_id": 1,
                        "role": "owner",
                        "username": "zhangsan",
                        "email": "zhangsan@example.com"
                      },
                      {
                        "id": 2,
                        "project_id": 1,
                        "user_id": 2,
                        "role": "developer",
                        "username": "lisi",
                        "email": "lisi@example.com"
                      }
                    ]
                  }
                }
              }
            }
          },
          "404": {
            "description": "项目不存在"
          },
          "422": {
            "description": "参数验证错误"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ProjectMemberListResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/ProjectMemberResponse"
            },
            "type": "array",
            "title": "Items"
          },
          "total": {
            "type": "integer",
            "title": "Total"
          },
          "page": {
            "type": "integer",
            "title": "Page"
          },
          "pageSize": {
            "type": "integer",
            "title": "Pagesize"
          }
        },
        "type": "object",
        "required": [
          "items",
          "total",
          "page",
          "pageSize"
        ],
        "title": "ProjectMemberListResponse",
        "description": "Schema for paginated project member list response."
      },
      "ProjectMemberResponse": {
        "properties": {
          "user_id": {
            "type": "integer",
            "title": "User Id",
            "description": "用户ID"
          },
          "role": {
            "type": "string",
            "enum": [
              "owner",
              "maintainer",
              "developer",
              "member"
            ],
            "title": "Role",
            "description": "成员角色",
            "default": "developer"
          },
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "project_id": {
            "type": "integer",
            "title": "Project Id"
          },
          "joined_at": {
            "type": "string",
            "format": "date-time",
            "title": "Joined At"
          },
          "username": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Username"
          },
          "email": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Email"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "id",
          "project_id",
          "joined_at"
        ],
        "title": "ProjectMemberResponse",
        "description": "Schema for project member response with user details."
      }
    },
    "securitySchemes": {
      "OAuth2PasswordBearer": {
        "type": "oauth2",
        "flows": {
          "password": {
            "scopes": {},
            "tokenUrl": "/api/v1/auth/login"
          }
        }
      },
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}