{
  "openapi": "3.1.0",
  "info": {
    "title": "Coding Agent Stats",
    "description": "研发中心 Coding Agent 绩效统计平台",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/stats/personal/code": {
      "get": {
        "tags": [
          "personal-stats"
        ],
        "summary": "获取个人代码统计",
        "description": "获取指定用户在日期范围内的代码提交统计信息，包括总提交数、新增/删除代码行数、日均提交数等。默认统计最近30天。",
        "operationId": "get_personal_code_stats_api_v1_stats_personal_code_get",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer",
                  "exclusiveMinimum": 0
                },
                {
                  "type": "null"
                }
              ],
              "description": "User ID (optional, defaults to current user)",
              "examples": [
                1
              ],
              "title": "User Id"
            },
            "description": "User ID (optional, defaults to current user)"
          },
          {
            "name": "start_date",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "date"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Start date (YYYY-MM-DD format)",
              "title": "Start Date"
            },
            "description": "Start date (YYYY-MM-DD format)"
          },
          {
            "name": "end_date",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "date"
                },
                {
                  "type": "null"
                }
              ],
              "description": "End date (YYYY-MM-DD format)",
              "title": "End Date"
            },
            "description": "End date (YYYY-MM-DD format)"
          }
        ],
        "responses": {
          "200": {
            "description": "成功获取代码统计",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_PersonalCodeStatsResponse_"
                },
                "example": {
                  "code": 200,
                  "message": "success",
                  "data": {
                    "total_commits": 42,
                    "total_prs": 0,
                    "lines_added": 1250,
                    "lines_deleted": 320,
                    "avg_commits_per_day": 1.4
                  }
                }
              }
            }
          },
          "404": {
            "description": "User not found"
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "example": {
                  "detail": [
                    {
                      "loc": [
                        "query",
                        "user_id"
                      ],
                      "msg": "field required",
                      "type": "value_error.missing"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiResponse_PersonalCodeStatsResponse_": {
        "properties": {
          "code": {
            "type": "integer",
            "title": "Code",
            "description": "HTTP status code or custom code",
            "default": 200
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Response message",
            "default": "success"
          },
          "data": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/PersonalCodeStatsResponse"
              },
              {
                "type": "null"
              }
            ],
            "description": "Response data"
          }
        },
        "type": "object",
        "title": "ApiResponse[PersonalCodeStatsResponse]"
      },
      "PersonalCodeStatsResponse": {
        "properties": {
          "total_commits": {
            "type": "integer",
            "title": "Total Commits",
            "description": "总提交数",
            "default": 0
          },
          "total_prs": {
            "type": "integer",
            "title": "Total Prs",
            "description": "总PR数",
            "default": 0
          },
          "lines_added": {
            "type": "integer",
            "title": "Lines Added",
            "description": "新增代码行数",
            "default": 0
          },
          "lines_deleted": {
            "type": "integer",
            "title": "Lines Deleted",
            "description": "删除代码行数",
            "default": 0
          },
          "avg_commits_per_day": {
            "type": "number",
            "title": "Avg Commits Per Day",
            "description": "日均提交数",
            "default": 0.0
          }
        },
        "type": "object",
        "title": "PersonalCodeStatsResponse",
        "description": "Schema for personal code statistics response."
      }
    },
    "securitySchemes": {
      "OAuth2PasswordBearer": {
        "type": "oauth2",
        "flows": {
          "password": {
            "scopes": {},
            "tokenUrl": "/api/v1/auth/login"
          }
        }
      },
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}