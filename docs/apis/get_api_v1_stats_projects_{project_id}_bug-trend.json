{
  "openapi": "3.1.0",
  "info": {
    "title": "Coding Agent Stats",
    "description": "研发中心 Coding Agent 绩效统计平台",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/stats/projects/{project_id}/bug-trend": {
      "get": {
        "tags": [
          "project-stats"
        ],
        "summary": "获取项目Bug趋势",
        "description": "获取指定项目在日期范围内的Bug趋势数据，包括每日创建的Bug数和解决的Bug数。默认统计最近30天。",
        "operationId": "get_project_bug_trend_api_v1_stats_projects__project_id__bug_trend_get",
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Project Id"
            }
          },
          {
            "name": "start_date",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "date"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Start date (YYYY-MM-DD format)",
              "title": "Start Date"
            },
            "description": "Start date (YYYY-MM-DD format)"
          },
          {
            "name": "end_date",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "date"
                },
                {
                  "type": "null"
                }
              ],
              "description": "End date (YYYY-MM-DD format)",
              "title": "End Date"
            },
            "description": "End date (YYYY-MM-DD format)"
          }
        ],
        "responses": {
          "200": {
            "description": "成功获取Bug趋势",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_BugTrendResponse_"
                },
                "example": {
                  "code": 200,
                  "message": "success",
                  "data": {
                    "dates": [
                      "2026-03-01",
                      "2026-03-02",
                      "2026-03-03"
                    ],
                    "created": [
                      2,
                      1,
                      3
                    ],
                    "resolved": [
                      1,
                      2,
                      1
                    ]
                  }
                }
              }
            }
          },
          "404": {
            "description": "Project not found"
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "example": {
                  "detail": [
                    {
                      "loc": [
                        "query",
                        "start_date"
                      ],
                      "msg": "invalid date format",
                      "type": "value_error.date"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiResponse_BugTrendResponse_": {
        "properties": {
          "code": {
            "type": "integer",
            "title": "Code",
            "description": "HTTP status code or custom code",
            "default": 200
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Response message",
            "default": "success"
          },
          "data": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/BugTrendResponse"
              },
              {
                "type": "null"
              }
            ],
            "description": "Response data"
          }
        },
        "type": "object",
        "title": "ApiResponse[BugTrendResponse]"
      },
      "BugTrendResponse": {
        "properties": {
          "dates": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Dates",
            "description": "日期列表"
          },
          "created": {
            "items": {
              "type": "integer"
            },
            "type": "array",
            "title": "Created",
            "description": "创建的Bug数"
          },
          "resolved": {
            "items": {
              "type": "integer"
            },
            "type": "array",
            "title": "Resolved",
            "description": "解决的Bug数"
          }
        },
        "type": "object",
        "title": "BugTrendResponse",
        "description": "Schema for bug trend response."
      }
    },
    "securitySchemes": {
      "OAuth2PasswordBearer": {
        "type": "oauth2",
        "flows": {
          "password": {
            "scopes": {},
            "tokenUrl": "/api/v1/auth/login"
          }
        }
      },
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}