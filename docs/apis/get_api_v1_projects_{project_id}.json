{
  "openapi": "3.1.0",
  "info": {
    "title": "Coding Agent Stats",
    "description": "研发中心 Coding Agent 绩效统计平台",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/projects/{project_id}": {
      "get": {
        "tags": [
          "projects"
        ],
        "summary": "获取项目详情",
        "description": "获取指定项目的详细信息，包括项目成员列表。",
        "operationId": "get_project_api_v1_projects__project_id__get",
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Project Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功获取项目详情",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectResponse"
                },
                "example": {
                  "id": 1,
                  "name": "示例项目",
                  "code": "demo-project",
                  "description": "这是一个示例项目",
                  "stage": "development",
                  "status": "active",
                  "start_date": "2026-01-01",
                  "end_date": "2026-12-31",
                  "manager_id": 1,
                  "created_at": "2026-01-01T00:00:00",
                  "updated_at": "2026-03-31T00:00:00",
                  "members": [
                    {
                      "id": 1,
                      "project_id": 1,
                      "user_id": 1,
                      "role": "owner",
                      "username": "zhangsan",
                      "email": "zhangsan@example.com"
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "项目不存在"
          },
          "422": {
            "description": "参数验证错误"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ProjectMemberResponse": {
        "properties": {
          "user_id": {
            "type": "integer",
            "title": "User Id",
            "description": "用户ID"
          },
          "role": {
            "type": "string",
            "enum": [
              "owner",
              "maintainer",
              "developer",
              "member"
            ],
            "title": "Role",
            "description": "成员角色",
            "default": "developer"
          },
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "project_id": {
            "type": "integer",
            "title": "Project Id"
          },
          "joined_at": {
            "type": "string",
            "format": "date-time",
            "title": "Joined At"
          },
          "username": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Username"
          },
          "email": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Email"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "id",
          "project_id",
          "joined_at"
        ],
        "title": "ProjectMemberResponse",
        "description": "Schema for project member response with user details."
      },
      "ProjectResponse": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "code": {
            "type": "string",
            "title": "Code"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "stage": {
            "type": "string",
            "title": "Stage"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "archived",
              "deleted"
            ],
            "title": "Status"
          },
          "start_date": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "Start Date"
          },
          "end_date": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "End Date"
          },
          "manager_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Manager Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "members": {
            "items": {
              "$ref": "#/components/schemas/ProjectMemberResponse"
            },
            "type": "array",
            "title": "Members",
            "default": []
          }
        },
        "type": "object",
        "required": [
          "id",
          "name",
          "code",
          "stage",
          "status",
          "created_at",
          "updated_at"
        ],
        "title": "ProjectResponse",
        "description": "Schema for project response."
      }
    },
    "securitySchemes": {
      "OAuth2PasswordBearer": {
        "type": "oauth2",
        "flows": {
          "password": {
            "scopes": {},
            "tokenUrl": "/api/v1/auth/login"
          }
        }
      },
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}