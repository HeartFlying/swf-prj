{
  "openapi": "3.1.0",
  "info": {
    "title": "Coding Agent Stats",
    "description": "研发中心 Coding Agent 绩效统计平台",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/sync/zendao": {
      "post": {
        "tags": [
          "sync"
        ],
        "summary": "触发ZenTao数据同步",
        "description": "创建ZenTao缺陷跟踪系统数据同步任务，包括Bug数据。任务将异步执行。需要管理员权限。",
        "operationId": "sync_zendao_api_v1_sync_zendao_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SyncZendaoRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "同步任务已创建并排队",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_SyncTaskCreateData_"
                },
                "example": {
                  "code": 202,
                  "message": "ZenTao sync task created and queued for execution.",
                  "data": {
                    "task_id": 125,
                    "source": "zendao",
                    "status": "pending"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden - admin permission required"
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "example": {
                  "detail": [
                    {
                      "loc": [
                        "body",
                        "project_id"
                      ],
                      "msg": "field required",
                      "type": "value_error.missing"
                    }
                  ]
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "ApiResponse_SyncTaskCreateData_": {
        "properties": {
          "code": {
            "type": "integer",
            "title": "Code",
            "description": "HTTP status code or custom code",
            "default": 200
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Response message",
            "default": "success"
          },
          "data": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/SyncTaskCreateData"
              },
              {
                "type": "null"
              }
            ],
            "description": "Response data"
          }
        },
        "type": "object",
        "title": "ApiResponse[SyncTaskCreateData]"
      },
      "SyncTaskCreateData": {
        "properties": {
          "task_id": {
            "type": "integer",
            "title": "Task Id",
            "description": "任务ID"
          },
          "source": {
            "type": "string",
            "title": "Source",
            "description": "同步来源"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "running",
              "completed",
              "failed"
            ],
            "title": "Status",
            "description": "任务状态"
          }
        },
        "type": "object",
        "required": [
          "task_id",
          "source",
          "status"
        ],
        "title": "SyncTaskCreateData",
        "description": "Data for sync task creation response."
      },
      "SyncZendaoRequest": {
        "properties": {
          "project_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Project Id",
            "description": "项目ID（为空则同步所有项目）"
          },
          "sync_type": {
            "type": "string",
            "title": "Sync Type",
            "description": "同步类型: full_sync, incremental_sync",
            "default": "incremental_sync"
          },
          "start_date": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "Start Date",
            "description": "开始日期"
          },
          "end_date": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "End Date",
            "description": "结束日期"
          }
        },
        "type": "object",
        "title": "SyncZendaoRequest",
        "description": "Schema for Zendao sync request."
      }
    },
    "securitySchemes": {
      "OAuth2PasswordBearer": {
        "type": "oauth2",
        "flows": {
          "password": {
            "scopes": {},
            "tokenUrl": "/api/v1/auth/login"
          }
        }
      },
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}