          "user_id",
          "username"
        ],
        "title": "MemberStat",
        "description": "Schema for member statistics."
      },
      "ProjectDashboardResponse": {
        "properties": {
          "project_id": {
            "type": "integer",
            "title": "Project Id",
            "description": "项目ID"
          },
          "project_name": {
            "type": "string",
            "title": "Project Name",
            "description": "项目名称"
          },
          "total_stats": {
            "$ref": "#/components/schemas/TotalStats",
            "description": "项目总体统计"
          },
          "member_stats": {
            "items": {
              "$ref": "#/components/schemas/MemberStat"
            },
            "type": "array",
            "title": "Member Stats",
            "description": "成员统计列表"
          },
          "language_distribution": {
            "items": {
              "$ref": "#/components/schemas/LanguageDistribution"
            },
            "type": "array",
            "title": "Language Distribution",
            "description": "语言分布"
          },
          "commit_trend": {
            "$ref": "#/components/schemas/CommitTrend",
            "description": "提交趋势"
          }
        },
        "type": "object",
        "required": [
          "project_id",
          "project_name"
        ],
        "title": "ProjectDashboardResponse",
        "description": "Schema for project dashboard statistics response.\n\nMatches frontend expected structure in ProjectDashboard type."
      },
      "TotalStats": {
        "properties": {
          "commits": {
            "type": "integer",
            "title": "Commits",
            "description": "总提交数",
            "default": 0
          },
          "contributors": {
            "type": "integer",
            "title": "Contributors",
            "description": "贡献者数量",
            "default": 0
          },
          "lines_of_code": {
            "type": "integer",
            "title": "Lines Of Code",
            "description": "代码行数",
            "default": 0
          },
          "pull_requests": {
            "type": "integer",
            "title": "Pull Requests",
            "description": "PR数量",
            "default": 0
          }
        },
        "type": "object",
        "title": "TotalStats",
        "description": "Schema for project total statistics."
      }
    },
    "securitySchemes": {
