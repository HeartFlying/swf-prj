{
  "openapi": "3.1.0",
  "info": {
    "title": "Coding Agent Stats",
    "description": "研发中心 Coding Agent 绩效统计平台",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/projects": {
      "get": {
        "tags": [
          "projects"
        ],
        "summary": "获取项目列表",
        "description": "获取分页的项目列表，支持按状态、阶段筛选和关键词搜索。",
        "operationId": "list_projects_api_v1_projects_get",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "description": "页码 (从1开始)",
              "examples": [
                1
              ],
              "default": 1,
              "title": "Page"
            },
            "description": "页码 (从1开始)"
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "minimum": 1,
              "description": "每页数量 (1-100)",
              "examples": [
                20
              ],
              "default": 20,
              "title": "Pagesize"
            },
            "description": "每页数量 (1-100)"
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "按状态筛选 (如: active, inactive)",
              "examples": [
                "active"
              ],
              "title": "Status"
            },
            "description": "按状态筛选 (如: active, inactive)"
          },
          {
            "name": "stage",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "按阶段筛选 (如: planning, development, testing)",
              "examples": [
                "development"
              ],
              "title": "Stage"
            },
            "description": "按阶段筛选 (如: planning, development, testing)"
          },
          {
            "name": "keyword",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "搜索关键词（匹配项目名称或代码）",
              "examples": [
                "demo"
              ],
              "title": "Keyword"
            },
            "description": "搜索关键词（匹配项目名称或代码）"
          }
        ],
        "responses": {
          "200": {
            "description": "成功获取项目列表",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectListResponse"
                },
                "example": {
                  "items": [
                    {
                      "id": 1,
                      "name": "示例项目",
                      "code": "demo-project",
                      "description": "这是一个示例项目",
                      "stage": "development",
                      "status": "active",
                      "start_date": "2026-01-01",
                      "end_date": "2026-12-31",
                      "manager_id": 1,
                      "created_at": "2026-01-01T00:00:00",
                      "updated_at": "2026-03-31T00:00:00"
                    }
                  ],
                  "total": 50,
                  "page": 1,
                  "pageSize": 20
                }
              }
            }
          },
          "422": {
            "description": "参数验证错误"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ProjectInDB": {
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 100,
            "minLength": 1,
            "title": "Name",
            "description": "项目名称"
          },
          "code": {
            "type": "string",
            "maxLength": 50,
            "minLength": 1,
            "title": "Code",
            "description": "项目编号"
          },
          "description": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 1000
              },
              {
                "type": "null"
              }
            ],
            "title": "Description",
            "description": "项目描述"
          },
          "stage": {
            "type": "string",
            "title": "Stage",
            "description": "项目阶段"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "archived",
              "deleted"
            ],
            "title": "Status",
            "description": "项目状态",
            "default": "active"
          },
          "start_date": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "Start Date",
            "description": "开始日期"
          },
          "end_date": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "End Date",
            "description": "结束日期"
          },
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "manager_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Manager Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          }
        },
        "type": "object",
        "required": [
          "name",
          "code",
          "stage",
          "id",
          "created_at",
          "updated_at"
        ],
        "title": "ProjectInDB",
        "description": "Schema for project as stored in database."
      },
      "ProjectListResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/ProjectInDB"
            },
            "type": "array",
            "title": "Items"
          },
          "total": {
            "type": "integer",
            "title": "Total"
          },
          "page": {
            "type": "integer",
            "title": "Page"
          },
          "pageSize": {
            "type": "integer",
            "title": "Pagesize"
          }
        },
        "type": "object",
        "required": [
          "items",
          "total",
          "page",
          "pageSize"
        ],
        "title": "ProjectListResponse",
        "description": "Schema for paginated project list response."
      }
    },
    "securitySchemes": {
      "OAuth2PasswordBearer": {
        "type": "oauth2",
        "flows": {
          "password": {
            "scopes": {},
            "tokenUrl": "/api/v1/auth/login"
          }
        }
      },
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}