{
  "openapi": "3.1.0",
  "info": {
    "title": "Coding Agent Stats",
    "description": "研发中心 Coding Agent 绩效统计平台",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/stats/projects/{project_id}/code-rank": {
      "get": {
        "tags": [
          "project-stats"
        ],
        "summary": "获取项目代码量排行",
        "description": "获取项目成员的代码量排行榜，按代码行数排序。可指定返回数量限制。",
        "operationId": "get_project_code_rank_api_v1_stats_projects__project_id__code_rank_get",
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Project Id"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "minimum": 1,
              "description": "Maximum number of results to return (1-100)",
              "examples": [
                20
              ],
              "default": 20,
              "title": "Limit"
            },
            "description": "Maximum number of results to return (1-100)"
          }
        ],
        "responses": {
          "200": {
            "description": "成功获取代码量排行",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_list_CodeRankResponse__"
                },
                "example": {
                  "code": 200,
                  "message": "success",
                  "data": [
                    {
                      "user_id": 1,
                      "username": "zhangsan",
                      "lines_added": 2500,
                      "lines_deleted": 500,
                      "total_lines": 2000
                    },
                    {
                      "user_id": 2,
                      "username": "lisi",
                      "lines_added": 1800,
                      "lines_deleted": 300,
                      "total_lines": 1500
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Project not found"
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "example": {
                  "detail": [
                    {
                      "loc": [
                        "query",
                        "limit"
                      ],
                      "msg": "ensure this value is less than or equal to 100",
                      "type": "value_error.number.not_le"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CodeRankResponse": {
        "properties": {
          "user_id": {
            "type": "integer",
            "title": "User Id",
            "description": "用户ID"
          },
          "username": {
            "type": "string",
            "title": "Username",
            "description": "用户名"
          },
          "lines_added": {
            "type": "integer",
            "title": "Lines Added",
            "description": "新增代码行数",
            "default": 0
          },
          "lines_deleted": {
            "type": "integer",
            "title": "Lines Deleted",
            "description": "删除代码行数",
            "default": 0
          },
          "total_lines": {
            "type": "integer",
            "title": "Total Lines",
            "description": "总代码行数",
            "default": 0
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "username"
        ],
        "title": "CodeRankResponse",
        "description": "Schema for code rank response."
      },
      "ApiResponse_list_CodeRankResponse__": {
        "properties": {
          "code": {
            "type": "integer",
            "title": "Code",
            "description": "HTTP status code or custom code",
            "default": 200
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Response message",
            "default": "success"
          },
          "data": {
            "anyOf": [
              {
                "items": {
                  "$ref": "#/components/schemas/CodeRankResponse"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Data",
            "description": "Response data"
          }
        },
        "type": "object",
        "title": "ApiResponse[list[CodeRankResponse]]"
      }
    },
    "securitySchemes": {
      "OAuth2PasswordBearer": {
        "type": "oauth2",
        "flows": {
          "password": {
            "scopes": {},
            "tokenUrl": "/api/v1/auth/login"
          }
        }
      },
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}