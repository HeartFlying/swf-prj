            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Project Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProjectUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "项目更新成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectInDB"
                },
                "example": {
                  "id": 1,
                  "name": "示例项目（已更新）",
                  "code": "demo-project",
                  "description": "更新后的描述",
                  "stage": "testing",
                  "status": "active",
                  "start_date": "2026-01-01",
                  "end_date": "2026-12-31",
                  "manager_id": 1,
                  "created_at": "2026-01-01T00:00:00",
                  "updated_at": "2026-03-31T12:00:00"
                }
              }
            }
          },
          "401": {
            "description": "未授权访问"
          },
          "403": {
            "description": "权限不足（需要管理员权限）"
          },
          "404": {
            "description": "项目不存在"
          },
          "409": {
            "description": "项目代码已存在"
          },
          "422": {
            "description": "参数验证错误"
          }
        }
      }
    }
  },
