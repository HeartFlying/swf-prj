{
  "openapi": "3.1.0",
  "info": {
    "title": "Coding Agent Stats",
    "description": "研发中心 Coding Agent 绩效统计平台",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/stats/projects/{project_id}": {
      "get": {
        "tags": [
          "project-stats"
        ],
        "summary": "获取项目统计概览",
        "description": "获取指定项目的统计概览，包括总提交数、总Token使用量、活跃成员数、Bug数量。默认统计最近30天的数据。",
        "operationId": "get_project_stats_api_v1_stats_projects__project_id__get",
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Project Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功获取项目统计",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse_ProjectStatsResponse_"
                },
                "example": {
                  "code": 200,
                  "message": "success",
                  "data": {
                    "project_id": 1,
                    "project_name": "示例项目",
                    "total_commits": 150,
                    "total_tokens": 50000,
                    "active_members": 8,
                    "bug_count": 12
                  }
                }
              }
            }
          },
          "404": {
            "description": "Project not found"
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "example": {
                  "detail": [
                    {
                      "loc": [
                        "path",
                        "project_id"
                      ],
                      "msg": "ensure this value is greater than 0",
                      "type": "value_error.number.not_gt"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ProjectStatsResponse": {
        "properties": {
          "project_id": {
            "type": "integer",
            "title": "Project Id",
            "description": "项目ID"
          },
          "project_name": {
            "type": "string",
            "title": "Project Name",
            "description": "项目名称"
          },
          "total_commits": {
            "type": "integer",
            "title": "Total Commits",
            "description": "总提交数",
            "default": 0
          },
          "total_tokens": {
            "type": "integer",
            "title": "Total Tokens",
            "description": "总Token使用量",
            "default": 0
          },
          "active_members": {
            "type": "integer",
            "title": "Active Members",
            "description": "活跃成员数",
            "default": 0
          },
          "bug_count": {
            "type": "integer",
            "title": "Bug Count",
            "description": "Bug数量",
            "default": 0
          }
        },
        "type": "object",
        "required": [
          "project_id",
          "project_name"
        ],
        "title": "ProjectStatsResponse",
        "description": "Schema for project statistics response."
      },
      "ApiResponse_ProjectStatsResponse_": {
        "properties": {
          "code": {
            "type": "integer",
            "title": "Code",
            "description": "HTTP status code or custom code",
            "default": 200
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Response message",
            "default": "success"
          },
          "data": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ProjectStatsResponse"
              },
              {
                "type": "null"
              }
            ],
            "description": "Response data"
          }
        },
        "type": "object",
        "title": "ApiResponse[ProjectStatsResponse]"
      }
    },
    "securitySchemes": {
      "OAuth2PasswordBearer": {
        "type": "oauth2",
        "flows": {
          "password": {
            "scopes": {},
            "tokenUrl": "/api/v1/auth/login"
          }
        }
      },
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}